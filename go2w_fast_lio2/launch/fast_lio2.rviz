          Value: true
        FL_thigh:
          Value: true
        FR_calf:
          Value: true
        FR_calflower:
          Value: true
        FR_calflower1:
          Value: true
        FR_foot:
          Value: true
        FR_foot_motor:
          Value: true
        FR_hip:
          Value: true
        FR_thigh:
          Value: true
        Head_lower:
          Value: true
        Head_upper:
          Value: true
        RL_calf:
          Value: true
        RL_calflower:
          Value: true
        RL_calflower1:
          Value: true
        RL_foot:
          Value: true
        RL_foot_motor:
          Value: true
        RL_hip:
          Value: true
        RL_thigh:
          Value: true
        RR_calf:
          Value: true
        RR_calflower:
          Value: true
        RR_calflower1:
          Value: true
        RR_foot:
          Value: true
        RR_foot_motor:
          Value: true
        RR_hip:
          Value: true
        RR_thigh:
          Value: true
        base:
          Value: true
        base_footprint:
          Value: true
        hesai_lidar:
          Value: true
        imu:
          Value: true
        radar:
          Value: true
      Marker Scale: 0.5
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: false
      Tree:
        base_footprint:
          base:
            FL_hip:
              FL_thigh:
                FL_calf:
                  FL_calflower:
                    FL_calflower1:
                      {}
                  FL_foot:
                    {}
                  FL_foot_motor:
                    {}
            FR_hip:
              FR_thigh:
                FR_calf:
                  FR_calflower:
                    FR_calflower1:
                      {}
                  FR_foot:
                    {}
                  FR_foot_motor:
                    {}
            Head_upper:
              Head_lower:
                {}
            RL_hip:
              RL_thigh:
                RL_calf:
                  RL_calflower:
                    RL_calflower1:
                      {}
                  RL_foot:
                    {}
                  RL_foot_motor:
                    {}
            RR_hip:
              RR_thigh:
                RR_calf:
                  RR_calflower:
                    RR_calflower1:
                      {}
                  RR_foot:
                    {}
                  RR_foot_motor:
                    {}
            hesai_lidar:
              {}
            imu:
              {}
            radar:
              {}
      Update Interval: 0
      Value: true
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 255; 255; 255
      Color Transformer: Intensity
