[Unit]
Description=OM6DOF perception-driven MoveIt pickup backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=/home/unitree
ExecStart=/bin/bash -c 'set -e; source /home/unitree/unitree_ros2/setup.sh; source /home/unitree/ros2_ws/install/setup.bash; exec ros2 launch om6dof_pick_and_place perception_pick.launch.py'
KillMode=control-group
KillSignal=SIGINT
TimeoutStopSec=20
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
